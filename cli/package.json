{
  "name": "kimaki",
  "module": "index.ts",
  "type": "module",
  "version": "0.16.0",
  "scripts": {
    "dev": "tsx src/bin.ts",
    "prepublishOnly": "pnpm sync-skills && pnpm build",
    "build": "rm -rf dist && pnpm generate && pnpm tsc",
    "watch": "tsx scripts/watch-session.ts",
    "generate": "pnpm generate:sql",
    "generate:sql": "tsx scripts/generate-schema-sql.ts",
    "pcm-to-mp3": "bun scripts/pcm-to-mp3",
    "test": "vitest",
    "validate-typing-indicator": "doppler run -- tsx scripts/validate-typing-indicator.ts",
    "test:send": "tsx send-test-message.ts",
    "register-commands": "tsx scripts/register-commands.ts",
    "lint": "lintcn lint",
    "format": "oxfmt src",
    "sync-skills": "mkdir -p skills && cp -R ../skills/. skills && tsx scripts/sync-skills.ts"
  },
  "repository": "https://github.com/remorses/kimaki",
  "bin": "bin.js",
  "files": [
    "dist",
    "src",
    "skills",
    "bin.js"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/heic-convert": "^2.1.0",
    "@types/json-schema": "^7.0.15",
    "@types/ms": "^2.1.0",
    "@types/node": "^24.3.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/ws": "^8.18.1",
    "db": "workspace:^",
    "discord-digital-twin": "workspace:^",
    "drizzle-kit": "1.0.0-beta.22",
    "eventsource-parser": "^3.0.6",
    "lintcn": "^0.7.1",
    "opencode-cached-provider": "workspace:^",
    "opencode-deterministic-provider": "workspace:^",
    "tsx": "^4.20.5",
    "undici": "^8.0.2"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/openai": "^3.0.31",
    "@ai-sdk/provider": "^3.0.8",
    "@clack/prompts": "^1.3.0",
    "@discordjs/voice": "^0.19.2",
    "@google/genai": "^1.46.0",
    "@libsql/client": "^0.17.2",
    "@opencode-ai/plugin": "^1.16.2",
    "@opencode-ai/sdk": "^1.16.2",
    "@parcel/watcher": "^2.5.6",
    "@purinton/resampler": "^1.0.4",
    "cron-parser": "^5.5.0",
    "diff": "^8.0.4",
    "discord.js": "^14.26.3",
    "domhandler": "^6.0.1",
    "drizzle-orm": "1.0.0-beta.22",
    "errore": "workspace:^",
    "goke": "^6.9.0",
    "htmlparser2": "^12.0.0",
    "kitty-graphics-agent": "^0.0.5",
    "libsql": "^0.5.22",
    "libsqlproxy": "workspace:^",
    "marked": "^17.0.5",
    "mime": "^4.1.0",
    "opencode-injection-guard": "workspace:^",
    "opusscript": "^0.0.8",
    "picocolors": "^1.1.1",
    "pretty-ms": "^9.3.0",
    "proper-lockfile": "^4.1.2",
    "string-dedent": "^3.0.2",
    "traforo": "workspace:^",
    "ws": "^8.19.0",
    "xdg-basedir": "^5.1.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "optionalDependencies": {
    "@snazzah/davey": "^0.1.10",
    "heic-convert": "^2.1.0",
    "prism-media": "^1.3.5",
    "sharp": "^0.34.5"
  }
